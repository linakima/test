		160, 164, 166, 167, 169, 171, 172, 173, 174, 176, 177, 181, 182, 183, 187,
		1118, 1119, 1168, 1169,
		8211, 8212, 8216, 8217, 8218, 8220, 8221, 8222, 8224, 8225, 8226, 8230, 8240, 8249, 8250, 8364, 8470, 8482,
	], function (idx, char_code) {
		cp1251_char_codes[char_code] = true;
	});

	String.prototype.to1251 = function () {
		var txt_js = this + '';
		var txt_1251 = '';
		var txt_len = txt_js.length;

		for (var i = 0; i < txt_len; i++) {
			var c = txt_js.charCodeAt(i);
			if ((c > 1037 && c < 1104) || c < 128 || (c > 1104 && c < 1117) || (c > 1024 && c < 1037) || cp1251_char_codes[c] != null) {
				txt_1251 += txt_js[i];
			} else {
				txt_1251 += '&#' + c + ';';
			}
		}
		return txt_1251;
	};

	String.prototype.highlight_non_1251 = function () {
		var txt_js = this + '';
		var txt_hl = '';
		var txt_len = txt_js.length;

		for (var i = 0; i < txt_len; i++) {
			var c = txt_js.charCodeAt(i);
			if ((c > 1037 && c < 1104) || c < 128 || (c > 1104 && c < 1117) || (c > 1024 && c < 1037) || cp1251_char_codes[c] != null) {
				txt_hl += txt_js[i];
			} else {
				txt_hl += '<em class="hl-non-1251">' + txt_js[i] + '</em>';
			}
		}
		return txt_hl;
	};

	String.prototype.count_as_1251 = function () {
		var txt_js = this.toString();
		var len = txt_js.length;
		var cnt = len;

		for (var i = 0; i < len; i++) {
			var c = txt_js.charCodeAt(i);
			if ((c > 1037 && c < 1104) || c < 128 || (c > 1104 && c < 1117) || (c > 1024 && c < 1037) || cp1251_char_codes[c] != null) {
				continue;
			}
			cnt += 2 + c.toString().length;
		}
		return cnt;
	};
})();



